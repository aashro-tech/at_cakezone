{
    "name": "aashro/at-cakezone",
    "type": "typo3-cms-extension",
    "description": "Modern TYPO3 v13 bakery template built with Content Blocks for showcasing cakes, menus, and bakery services.",
    "authors": [
        {
            "name": "Aashro Tech",
            "email": "info@aashro.com",
            "role": "Developer",
            "homepage": "https://www.aashro.com/"
        }
    ],
    "license": "GPL-2.0-or-later",
    "require": {
        "typo3/cms-core": "^13.4",
        "friendsoftypo3/content-blocks": "^1.0.0"
    },
    "autoload": {
        "psr-4": {
            "AASHRO\\AtCakezone\\": "Classes"
        }
    },
    "replace": {
        "typo3-ter/at-cakezone": "self.version"
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin"
    },
    "extra": {
        "typo3/cms": {
            "cms-package-dir": "{$vendor-dir}/typo3/cms",
            "web-dir": ".Build/public",
            "extension-key": "at_cakezone"
        }
    }
}